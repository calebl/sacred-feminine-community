<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white">Notifications</h1>
    <% if @notifications.any? { |n| !n.read? } %>
      <%= button_to notifications_mark_all_read_path,
          method: :post,
          class: "text-sm text-sf-gold hover:text-sf-gold/80 font-medium transition" do %>
        Mark all as read
      <% end %>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div class="text-center py-16 text-gray-400 dark:text-gray-500">
      <svg class="w-12 h-12 mx-auto mb-4 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
      </svg>
      <p class="text-lg">All caught up!</p>
      <p class="text-sm mt-2">No notifications yet.</p>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @notifications.each do |notification| %>
        <%= button_to notifications_reads_path(notification_id: notification.id),
            method: :post,
            class: "block w-full text-left #{ notification.read? ? 'bg-gray-50 dark:bg-gray-800/50' : 'bg-white dark:bg-gray-800' } rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-4 hover:shadow-md transition",
            data: { turbo_prefetch: false } do %>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 <%= notification_icon_bg(notification) %>">
              <% if notification.actor&.avatar&.attached? %>
                <%= image_tag notification.actor.avatar.variant(:display),
                    class: "w-10 h-10 rounded-full object-cover" %>
              <% elsif notification.event_type == "mention" %>
                <span class="text-lg">@</span>
              <% elsif notification.actor %>
                <%= notification.actor.name.first.upcase %>
              <% else %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                </svg>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sf-black dark:text-white truncate"><%= notification.title %></p>
              <p class="text-sm text-gray-500 dark:text-gray-400"><%= notification.body %> &middot; <%= time_ago_in_words(notification.created_at) %> ago</p>
            </div>
            <% unless notification.read? %>
              <span class="bg-sf-red rounded-full w-2.5 h-2.5 flex-shrink-0"></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
