<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white mb-2">Welcome, <%= current_user.name %></h1>
  <p class="text-gray-500 dark:text-gray-400 mb-8">Sacred Feminine Community</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <%= link_to map_path, class: "block p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 hover:shadow-md transition group" do %>
      <div class="w-12 h-12 rounded-xl bg-sf-blue/10 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
        <svg class="w-6 h-6 text-sf-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h3 class="font-display font-semibold text-sf-black dark:text-white mb-1">Community Map</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">See where our community members are around the world.</p>
    <% end %>

    <%= link_to cohorts_path, class: "block p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 hover:shadow-md transition group" do %>
      <div class="w-12 h-12 rounded-xl bg-sf-gold/10 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
        <svg class="w-6 h-6 text-sf-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </div>
      <h3 class="font-display font-semibold text-sf-black dark:text-white mb-1">My Cohorts</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Connect with your retreat groups.</p>
    <% end %>

    <%= link_to conversations_path, class: "block p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 hover:shadow-md transition group" do %>
      <div class="w-12 h-12 rounded-xl bg-sf-red/10 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
        <svg class="w-6 h-6 text-sf-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
      <h3 class="font-display font-semibold text-sf-black dark:text-white mb-1">Messages</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Private conversations with community members.</p>
    <% end %>
  </div>

  <% if current_user.admin? %>
    <div class="mt-8">
      <%= link_to admin_dashboard_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-sf-gold/10 text-sf-gold rounded-xl hover:bg-sf-gold/20 font-semibold text-sm transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Admin Dashboard
      <% end %>
    </div>
  <% end %>
</div>
