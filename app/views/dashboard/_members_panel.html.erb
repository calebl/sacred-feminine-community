<div class="mb-4 flex-shrink-0">
  <input type="text"
         data-member-search-target="input"
         data-action="input->member-search#filter"
         placeholder="Search by name or city..."
         class="w-full px-4 py-3 text-sm border border-gray-300 dark:border-gray-600 rounded-xl shadow-sm bg-white dark:bg-gray-700 text-sf-black dark:text-white placeholder-gray-400 focus:ring-sf-gold focus:border-sf-gold">
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 overflow-y-auto flex-1 min-h-0 content-start">
  <% @members.each do |member| %>
    <%= link_to profile_path(member),
                class: "flex items-center gap-3 p-4 rounded-xl hover:bg-sf-sand/10 dark:hover:bg-gray-700 transition",
                data: { member_search_target: "card", name: member.name, location: member.visible_location.to_s } do %>
      <div class="w-10 h-10 rounded-full bg-sf-sand/50 dark:bg-gray-600 flex items-center justify-center text-sm font-bold text-sf-black dark:text-white flex-shrink-0">
        <% if member.avatar.attached? %>
          <%= image_tag member.avatar.variant(:display), class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <%= member.name.first.upcase %>
        <% end %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-sf-black dark:text-white truncate"><%= member.name %></p>
        <% if member.visible_location.present? %>
          <p class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= member.visible_location %></p>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<p data-member-search-target="empty" class="hidden text-center text-gray-400 dark:text-gray-500 py-8">
  No members found matching your search.
</p>
