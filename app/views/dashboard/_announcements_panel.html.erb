<% if current_user.admin? && @new_announcement %>
  <div class="mb-6">
    <details class="group">
      <summary class="inline-flex items-center gap-2 btn-primary px-4 py-2 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        New Announcement
      </summary>

      <div class="mt-4 p-4 bg-white dark:bg-gray-800 rounded-xl border border-sf-sand/20 dark:border-gray-700">
        <%= form_with(model: [:admin, @new_announcement], class: "space-y-4") do |f| %>
          <%= hidden_field_tag :source, "dashboard" %>

          <div>
            <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :title, class: "w-full", required: true %>
          </div>

          <div>
            <%= f.label :body, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_area :body, rows: 3, class: "w-full", required: true %>
          </div>

          <div>
            <%= f.label :published_at, "Go Live Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.datetime_local_field :published_at, class: "w-full" %>
            <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Leave blank to go live immediately when activated.</p>
          </div>

          <div class="flex items-center gap-2">
            <%= f.check_box :active, class: "rounded border-gray-300 text-sf-gold focus:ring-sf-gold" %>
            <%= f.label :active, "Make this the active announcement", class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
          </div>

          <div>
            <%= f.submit "Create Announcement", class: "btn-primary px-5 py-2.5" %>
          </div>
        <% end %>
      </div>
    </details>
  </div>
<% end %>

<% if @announcements.any? %>
  <div class="space-y-4">
    <% @announcements.each do |announcement| %>
      <div class="p-4 rounded-xl border border-sf-sand/20 dark:border-gray-700">
        <h3 class="font-display font-semibold text-sf-black dark:text-white mb-1"><%= announcement.title %></h3>
        <p class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= announcement.body %></p>
        <% if announcement.published_at %>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-2"><%= announcement.published_at.strftime("%B %d, %Y") %></p>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-center text-gray-400 dark:text-gray-500 py-8">No announcements yet.</p>
<% end %>
