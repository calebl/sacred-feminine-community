<div id="<%= dom_id(direct_message) %>" class="flex items-start gap-3 p-2" data-sender-id="<%= direct_message.sender_id %>">
  <%= render "shared/avatar", user: direct_message.sender, size: :md %>
  <div data-message-bubble class="bg-sf-beige dark:bg-gray-700 rounded-xl px-4 py-2 max-w-[75%]">
    <p data-sender-name class="text-xs font-semibold text-sf-gold mb-1"><%= link_to direct_message.sender.name, profile_path(direct_message.sender), class: "hover:underline" %></p>
    <p class="text-sm text-sf-black dark:text-gray-100"><%= format_user_content(direct_message.body) %></p>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= time_ago_in_words(direct_message.created_at) %> ago</p>
  </div>
</div>
