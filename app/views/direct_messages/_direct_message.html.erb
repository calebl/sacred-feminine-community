<div id="<%= dom_id(direct_message) %>" class="flex items-start gap-3 p-2" data-sender-id="<%= direct_message.sender_id %>">
  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-sm font-bold text-sf-black dark:text-white">
    <% if direct_message.sender.avatar.attached? %>
      <%= image_tag direct_message.sender.avatar.variant(:display), class: "w-8 h-8 rounded-full object-cover" %>
    <% else %>
      <%= direct_message.sender.name.first.upcase %>
    <% end %>
  </div>
  <div data-message-bubble class="bg-sf-beige dark:bg-gray-700 rounded-xl px-4 py-2 max-w-[75%]">
    <p data-sender-name class="text-xs font-semibold text-sf-gold mb-1"><%= direct_message.sender.name %></p>
    <p class="text-sm text-sf-black dark:text-gray-100"><%= direct_message.body %></p>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= time_ago_in_words(direct_message.created_at) %> ago</p>
  </div>
</div>
