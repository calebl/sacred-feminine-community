<%= link_to group_path(group), class: "bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-hidden block hover:shadow-md transition" do %>
  <% if group.header_image.attached? %>
    <%= image_tag group.header_image.variant(resize_to_limit: [2400, 800]), class: "w-full" %>
  <% else %>
    <%= render "shared/header_image_placeholder", compact: true %>
  <% end %>
  <div class="p-5">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-lg font-display font-semibold text-sf-black dark:text-white"><%= group.name %></h2>
        <% if group.description.present? %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2"><%= group.description %></p>
        <% end %>
      </div>
      <div class="text-right">
        <p class="text-2xl font-bold text-sf-gold"><%= group.members.size %></p>
        <p class="text-xs text-gray-400 dark:text-gray-500">members</p>
      </div>
    </div>
  </div>
<% end %>
