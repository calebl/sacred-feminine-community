<%= link_to group_path(group), class: "bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-gold/20 dark:border-gray-700 overflow-hidden block hover:shadow-md transition" do %>
  <div class="relative">
    <div class="w-full h-16 bg-sf-gold/10"></div>
    <div class="absolute inset-0 flex items-center px-5">
      <h2 class="text-lg font-display font-semibold text-sf-gold"><%= group.name %></h2>
    </div>
  </div>
  <div class="p-5">
    <div class="flex items-center justify-between">
      <div>
        <% if group.description.present? %>
          <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2"><%= group.description %></p>
        <% end %>
      </div>
      <div class="text-right">
        <p class="text-2xl font-bold text-sf-gold"><%= group.members.size %></p>
        <p class="text-xs text-gray-400 dark:text-gray-500">members</p>
      </div>
    </div>
  </div>
<% end %>
