<div class="mb-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-gold/20 dark:border-gray-700 overflow-hidden">
  <div class="relative">
    <div class="w-full aspect-[8/1] bg-sf-gold/10"></div>
    <div class="absolute inset-0 flex items-center px-5">
      <h1 class="text-3xl font-display font-bold text-sf-gold"><%= @group.name %></h1>
    </div>
    <% if policy(@group).update? || @is_member || !@is_member %>
      <div class="absolute top-3 right-3" data-controller="dropdown" data-action="click@window->dropdown#close">
        <button data-action="click->dropdown#toggle" class="w-8 h-8 flex items-center justify-center rounded-full bg-sf-gold/20 hover:bg-sf-gold/40 transition cursor-pointer">
          <svg class="w-5 h-5 text-sf-gold" fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="5" r="1.5"/>
            <circle cx="12" cy="12" r="1.5"/>
            <circle cx="12" cy="19" r="1.5"/>
          </svg>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-1 w-40 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-sf-gold/20 dark:border-gray-700 overflow-hidden z-10">
          <% if policy(@group).update? %>
            <%= link_to "Edit", edit_group_path(@group), class: "block px-4 py-2.5 text-sm text-sf-black dark:text-white hover:bg-sf-gold/10 dark:hover:bg-gray-700 transition" %>
          <% end %>
          <% if !@is_member %>
            <%= button_to "Join Group", group_group_membership_path(@group), method: :post, class: "w-full text-left px-4 py-2.5 text-sm text-sf-black dark:text-white hover:bg-sf-gold/10 dark:hover:bg-gray-700 transition cursor-pointer" %>
          <% elsif policy(@group).leave? %>
            <%= button_to "Leave Group", group_group_membership_path(@group), method: :delete,
                class: "w-full text-left px-4 py-2.5 text-sm text-red-500 hover:bg-sf-gold/10 dark:hover:bg-gray-700 transition cursor-pointer",
                data: { turbo_confirm: "Leave this group?" } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
  <% if @group.description.present? %>
    <div class="p-5">
      <p class="text-sm text-gray-500 dark:text-gray-400"><%= @group.description %></p>
    </div>
  <% end %>
</div>

<% if @is_member %>
  <div data-controller="tabs" data-tabs-active-tab-value="<%= @active_tab %>">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-gold/20 dark:border-gray-700 overflow-hidden">
      <!-- Tab headers -->
      <div class="flex border-b border-sf-gold/20 dark:border-gray-700">
        <button data-tabs-target="tab" data-action="click->tabs#select"
                data-tab-name="feed"
                class="flex-1 px-4 py-3 text-sm font-semibold border-b-2 transition-colors cursor-pointer">
          Feed
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#select"
                data-tab-name="members"
                class="flex-1 px-4 py-3 text-sm font-semibold border-b-2 transition-colors cursor-pointer">
          Members (<%= @members.length %>)
        </button>
      </div>

      <!-- Feed panel -->
      <div data-tabs-target="panel" data-panel-name="feed">
        <div class="p-4" data-controller="inline-post-form">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-display font-semibold text-sf-black dark:text-white">Posts</h3>
            <button data-action="click->inline-post-form#toggle" class="btn-primary px-4 py-2">
              New Post
            </button>
          </div>

          <div data-inline-post-form-target="form" class="<%= @show_form ? '' : 'hidden' %>">
            <%= render "shared/inline_post_form", post: @group.group_posts.build, form_url: group_group_posts_path(@group), group_id: @group.id %>
          </div>

          <div class="space-y-3">
            <% @posts.each do |post| %>
              <%= render "shared/post_card", post: post, comments: post.group_post_comments,
                  comment_partial: "group_post_comments/group_post_comment",
                  comment_locals: { group: @group, group_post: post },
                  comment_form_model: [@group, post, GroupPostComment.new],
                  edit_path: edit_group_group_post_path(@group, post),
                  post_path: group_group_post_path(@group, post),
                  pin_path: group_group_post_pin_path(@group, post),
                  mention_data: { mention_group_id_value: @group.id } %>
            <% end %>
            <% if @posts.empty? %>
              <p class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">No posts yet. Be the first to share!</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Members panel -->
      <div data-tabs-target="panel" data-panel-name="members" class="hidden">
        <div class="p-6">
          <div class="space-y-3">
            <% @members.each do |member| %>
              <div class="flex items-center justify-between">
                <%= link_to profile_path(member), class: "flex items-center gap-3 hover:opacity-80 transition" do %>
                  <div class="w-8 h-8 rounded-full bg-sf-gold/50 dark:bg-gray-700 flex items-center justify-center text-sm font-bold text-sf-black dark:text-white flex-shrink-0">
                    <% if member.avatar.attached? %>
                      <%= image_tag member.avatar.variant(:display), class: "w-8 h-8 rounded-full object-cover" %>
                    <% else %>
                      <%= member.name.first.upcase %>
                    <% end %>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-sf-black dark:text-white"><%= member.name %></p>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-gold/20 dark:border-gray-700 p-8 text-center">
    <p class="text-gray-500 dark:text-gray-400 mb-4"><%= @group.members.size %> <%= "member".pluralize(@group.members.size) %></p>
    <p class="text-sm text-gray-400 dark:text-gray-500">Join this group to see posts and connect with members.</p>
  </div>
<% end %>
