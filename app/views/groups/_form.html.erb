<%= form_with(model: group, class: "space-y-6") do |f| %>
  <% if group.errors.any? %>
    <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
      <% group.errors.full_messages.each do |message| %>
        <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :name, class: "w-full", required: true %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full" %>
  </div>

  <div>
    <%= f.submit class: "w-full btn-primary" %>
  </div>
<% end %>
