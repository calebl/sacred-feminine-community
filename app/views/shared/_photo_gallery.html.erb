<% if post.photos.attached? %>
  <div class="mt-3 flex gap-2 overflow-x-auto" data-controller="lightbox" data-action="keydown@document->lightbox#closeOnEscape">
    <% post.photos.each do |photo| %>
      <button type="button"
              data-action="lightbox#open"
              data-lightbox-src-value="<%= rails_blob_path(photo, disposition: "inline") %>"
              class="cursor-pointer flex-shrink-0">
        <%= image_tag photo.variant(resize_to_limit: [400, 400]), class: "rounded-lg max-h-60 object-cover border border-gray-200 dark:border-gray-600 hover:opacity-90 transition" %>
      </button>
    <% end %>

    <!-- Lightbox modal -->
    <div data-lightbox-target="modal" data-action="click->lightbox#close"
         class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm">
      <button type="button" data-action="lightbox#close"
              class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition cursor-pointer text-2xl">&times;</button>
      <img data-lightbox-target="image" src="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
    </div>
  </div>
<% end %>
