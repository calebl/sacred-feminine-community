<div class="mb-4 p-4 bg-white dark:bg-gray-800 rounded-xl border border-sf-sand/20 dark:border-gray-700" data-controller="photo-upload">
  <%
    mention_data = {
      controller: "mention",
      mention_url_value: mention_searches_path
    }
    mention_data[:mention_cohort_id_value] = local_assigns[:cohort_id] if local_assigns[:cohort_id]
    mention_data[:mention_group_id_value] = local_assigns[:group_id] if local_assigns[:group_id]
    mention_data[:mention_initial_body_value] = post.body if post.persisted? && post.body.present?
  %>
  <%= tag.div data: mention_data, class: "relative" do %>
    <%= form_with(
      model: post,
      url: form_url,
      html: { multipart: true },
      class: "space-y-4"
    ) do |f| %>
      <% unless local_assigns[:editing] %>
        <input type="hidden" name="inline_feed" value="1">
      <% end %>

      <% if post.errors.any? %>
        <div class="rounded-xl p-4 bg-sf-red/10 text-red-800 dark:text-red-300 border border-sf-red/20">
          <ul class="list-disc list-inside text-sm">
            <% post.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.hidden_field :body, data: { mention_target: "hidden" } %>
        <div contenteditable="true"
             data-mention-target="input"
             data-action="input->mention#onInput keydown->mention#onKeydown blur->mention#hide paste->mention#onPaste"
             data-placeholder="Write your post... (@ to mention)"
             class="w-full min-h-[200px] resize-y border border-gray-300 dark:border-gray-600 rounded-xl shadow-sm px-4 py-3 text-sm dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-sf-gold focus:border-sf-gold"
             role="textbox"></div>
      </div>

      <%= f.file_field :photos, multiple: true, accept: "image/jpeg,image/png,image/gif,image/webp",
          class: "hidden", data: { photo_upload_target: "input", action: "photo-upload#preview" } %>

      <div data-photo-upload-target="preview" class="<%= local_assigns[:editing] && post.photos.attached? ? '' : 'hidden ' %>flex flex-wrap gap-2">
        <% if local_assigns[:editing] && post.photos.attached? %>
          <% post.photos.each do |photo| %>
            <div class="relative group" data-photo-wrapper>
              <%= image_tag photo.variant(resize_to_fill: [80, 80]), class: "w-20 h-20 object-cover rounded-lg border border-gray-200 dark:border-gray-600" %>
              <button type="button"
                      data-action="photo-upload#removeExisting"
                      data-photo-upload-id-param="<%= photo.id %>"
                      class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-red-500 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition cursor-pointer">&times;</button>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center justify-between">
        <button type="button" data-action="photo-upload#select" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-sf-gold dark:hover:text-sf-gold transition cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
          </svg>
          Add photos
        </button>

        <div class="flex gap-3">
          <% if local_assigns[:editing] %>
            <%= link_to "Cancel", form_url, class: "btn-tertiary py-2.5" %>
          <% else %>
            <button type="button"
                    data-action="click->inline-post-form#hide"
                    class="btn-tertiary py-2.5">Cancel</button>
          <% end %>
          <%= f.submit (local_assigns[:submit_label] || "Publish"), class: "btn-primary py-2.5" %>
        </div>
      </div>
    <% end %>
    <div data-mention-target="dropdown" class="hidden absolute left-0 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto"></div>
  <% end %>
</div>
