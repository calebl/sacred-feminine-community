<div class="max-w-2xl mx-auto px-4 py-8">
  <%= render "shared/back_header", path: back_path, title: "New Post" %>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-6">
    <%= form_with(url: form_url, method: :post, class: "space-y-4") do |f| %>
      <% if post.errors.any? %>
        <div class="rounded-xl p-4 bg-sf-red/10 text-red-800 dark:text-red-300 border border-sf-red/20">
          <ul class="list-disc list-inside text-sm">
            <% post.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.text_area :body, value: post.body, class: "w-full min-h-[200px] resize-y", placeholder: "Write your post...", required: true %>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Publish", class: "btn-primary py-2.5" %>
      </div>
    <% end %>
  </div>
</div>
