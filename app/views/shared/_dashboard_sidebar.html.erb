<%# Navigation links %>
<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-5">
  <h3 class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">Explore</h3>
  <div class="space-y-1">
    <% explore_items = [
      { name: "Announcements", tab: "announcements", icon: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" },
      { name: "Map", tab: "map", icon: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" },
      { name: "Members", tab: "members", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
      { name: "FAQs", tab: "faqs", icon: "M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" }
    ] %>
    <% explore_items.each do |item| %>
      <% active = defined?(@active_tab) && @active_tab == item[:tab] && !defined?(@active_cohort_id) %>
      <%= link_to authenticated_root_path(tab: item[:tab]),
          class: "block w-full px-3 py-2 rounded-lg text-sm transition-colors flex items-center gap-2 #{active ? 'bg-sf-gold/10 text-sf-gold font-semibold' : 'text-gray-700 dark:text-gray-300 hover:bg-sf-gold/10 hover:text-sf-gold'}" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/></svg>
        <%= item[:name] %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Cohorts section %>
<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-5">
  <h3 class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">My Cohorts</h3>
  <% if @sidebar_cohorts.any? %>
    <div class="space-y-1">
      <% @sidebar_cohorts.each do |cohort| %>
        <% active = defined?(@active_cohort_id) && @active_cohort_id == cohort.id %>
        <%= link_to cohort.name, cohort_path(cohort),
            class: "block w-full text-left px-3 py-2 rounded-lg text-sm transition-colors #{active ? 'bg-sf-gold/10 text-sf-gold font-semibold' : 'text-gray-700 dark:text-gray-300 hover:bg-sf-gold/10 hover:text-sf-gold'}" %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 dark:text-gray-500">No cohorts yet.</p>
  <% end %>
</div>

<%# Groups section %>
<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-5">
  <h3 class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">Groups</h3>
  <% if @sidebar_groups&.any? %>
    <div class="space-y-1">
      <% @sidebar_groups.each do |group| %>
        <% active = defined?(@active_group_id) && @active_group_id == group.id %>
        <%= link_to group.name, group_path(group),
            class: "block w-full text-left px-3 py-2 rounded-lg text-sm transition-colors #{active ? 'bg-sf-gold/10 text-sf-gold font-semibold' : 'text-gray-700 dark:text-gray-300 hover:bg-sf-gold/10 hover:text-sf-gold'}" %>
      <% end %>
    </div>
  <% end %>
  <%= link_to "Explore Groups", groups_path,
      class: "block w-full text-left px-3 py-2 rounded-lg text-sm text-gray-700 dark:text-gray-300 hover:bg-sf-gold/10 hover:text-sf-gold transition-colors mt-1" %>
</div>

<% if current_user.admin? %>
  <%= link_to admin_dashboard_path, class: "block px-4 py-3 bg-sf-gold/10 text-sf-gold rounded-xl hover:bg-sf-gold/20 font-semibold text-sm transition text-center" do %>
    <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    Admin Dashboard
  <% end %>
<% end %>
