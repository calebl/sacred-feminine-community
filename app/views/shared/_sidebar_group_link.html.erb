<% active = defined?(@active_group_id) && @active_group_id == group.id %>
<%= link_to group_path(group),
    id: dom_id(group, :sidebar),
    class: "w-full text-left px-3 py-2 rounded-lg text-sm transition-colors flex items-center gap-2 #{active ? 'bg-sf-gold/10 text-sf-gold font-semibold' : 'text-gray-700 dark:text-gray-300 hover:bg-sf-gold/10 hover:text-sf-gold'}",
    data: (local_assigns[:flash] ? { controller: "flash-highlight", flash_highlight_highlight_class: "bg-sf-gold/10 text-sf-gold" } : {}) do %>
  <%= render "shared/unread_dot", dom_id: dom_id(group, :unread_dot), unread: unread_group_ids.include?(group.id) %>
  <span class="truncate"><%= group.name %></span>
<% end %>
