<div data-push-notifications-target="banner"
     class="bg-sf-gold/10 border-b border-sf-gold/20 px-4 py-3"
     hidden>
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <svg class="w-5 h-5 text-sf-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
      </svg>
      <p class="text-sm text-sf-black dark:text-gray-200 truncate">
        Enable notifications to stay updated on new messages.
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <button data-action="push-notifications#enable"
              class="px-3 py-1.5 rounded-lg bg-sf-gold text-white text-sm font-semibold hover:bg-sf-gold/90 transition cursor-pointer">
        Enable
      </button>
      <button data-action="push-notifications#dismiss"
              class="p-1.5 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition cursor-pointer"
              title="Dismiss">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
</div>
