<%
  comments_by_parent = comments.group_by(&:parent_id)
  top_level_comments = (comments_by_parent[nil] || []).sort_by(&:created_at)
%>

<div id="<%= dom_id(post) %>" class="p-4 rounded-xl border border-sf-sand/20 dark:border-gray-700 bg-white dark:bg-gray-800" data-controller="replies-section post-edit">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <% if post.pinned? %>
        <div class="flex items-center mb-2">
          <span class="inline-flex items-center text-xs font-semibold text-sf-gold">
            <svg class="w-3.5 h-3.5 mr-0.5" fill="currentColor" viewBox="0 0 16 16">
              <path d="M4.146.146A.5.5 0 0 1 4.5 0h7a.5.5 0 0 1 .5.5c0 .68-.342 1.174-.646 1.479-.126.125-.25.224-.354.298v4.431l.078.048c.203.127.476.314.751.555C12.36 7.775 13 8.527 13 9.5a.5.5 0 0 1-.5.5h-4v4.5c0 .276-.224 1.5-.5 1.5s-.5-1.224-.5-1.5V10h-4a.5.5 0 0 1-.5-.5c0-.973.64-1.725 1.17-2.189A6 6 0 0 1 5 6.708V2.277a3 3 0 0 1-.354-.298C4.342 1.674 4 1.179 4 .5a.5.5 0 0 1 .146-.354z"/>
            </svg>
            Pinned
          </span>
        </div>
      <% end %>

      <!-- Author info -->
      <div class="flex items-center gap-3 text-sm text-gray-400 dark:text-gray-500 mb-3">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-xs font-bold">
            <% if post.user.avatar.attached? %>
              <%= image_tag post.user.avatar.variant(resize_to_fill: [24, 24]), class: "w-6 h-6 rounded-full object-cover" %>
            <% else %>
              <%= post.user.name.first.upcase %>
            <% end %>
          </div>
          <span><%= post.user.name %></span>
        </div>
        <span>&middot;</span>
        <span><%= time_ago_in_words(post.created_at) %> ago</span>
      </div>
    </div>

    <%# Three-dot menu %>
    <% if policy(post).edit? || policy(post).pin? || policy(post).destroy? %>
      <div class="relative flex-shrink-0" data-controller="dropdown" data-action="click@window->dropdown#close">
        <button type="button" data-action="dropdown#toggle" class="p-1 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition cursor-pointer">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
          </svg>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 top-8 z-20 w-36 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg py-1">
          <% if policy(post).edit? && local_assigns[:edit_path] %>
            <button type="button" data-action="post-edit#toggle dropdown#toggle"
                class="block w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition cursor-pointer">Edit</button>
          <% end %>
          <% if policy(post).pin? && local_assigns[:pin_path] %>
            <%= button_to post.pinned? ? "Unpin" : "Pin",
                local_assigns[:pin_path],
                method: :patch,
                class: "block w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition cursor-pointer" %>
          <% end %>
          <% if policy(post).destroy? && local_assigns[:post_path] %>
            <%= button_to "Delete", local_assigns[:post_path],
                method: :delete,
                class: "block w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition cursor-pointer",
                data: { turbo_confirm: "Delete this post?" } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Post body with truncation -->
  <div data-post-edit-target="display" data-controller="post-body">
    <div data-post-body-target="content" class="text-sm text-gray-700 dark:text-gray-300 line-clamp-[15] whitespace-pre-wrap"><%= render_with_mentions(post.body) %></div>
    <button type="button" data-post-body-target="toggle" data-action="post-body#toggle" class="hidden text-xs text-sf-gold hover:text-sf-gold/80 mt-1 cursor-pointer transition">view more</button>
    <%= render "shared/photo_gallery", post: post %>
  </div>

  <!-- Inline edit form (hidden by default) -->
  <% if policy(post).edit? && local_assigns[:edit_path] %>
    <div data-post-edit-target="form" class="hidden" data-controller="photo-upload">
      <%
        edit_mention_data = {
          controller: "mention",
          mention_url_value: mention_searches_path,
          mention_initial_body_value: post.body
        }
        (local_assigns[:mention_data] || {}).each do |key, value|
          edit_mention_data[key] = value
        end
      %>
      <%= tag.div data: edit_mention_data, class: "relative" do %>
        <%= form_with(
          model: post,
          url: local_assigns[:post_path],
          method: :patch,
          html: { multipart: true },
          class: "space-y-3",
          data: { turbo: true, action: "turbo:submit-start->post-edit#saveScroll" }
        ) do |f| %>
          <input type="hidden" name="inline_edit" value="1">
          <div>
            <%= f.hidden_field :body, data: { mention_target: "hidden" } %>
            <div contenteditable="true"
                 data-mention-target="input"
                 data-action="input->mention#onInput keydown->mention#onKeydown blur->mention#hide paste->mention#onPaste"
                 data-placeholder="Write your post... (@ to mention)"
                 class="w-full min-h-[120px] resize-y border border-gray-300 dark:border-gray-600 rounded-xl shadow-sm px-4 py-3 text-sm dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-sf-gold focus:border-sf-gold"
                 role="textbox"></div>
          </div>

          <%= f.file_field :photos, multiple: true, accept: "image/jpeg,image/png,image/gif,image/webp",
              class: "hidden", data: { photo_upload_target: "input", action: "photo-upload#preview" } %>
          <div data-photo-upload-target="preview" class="<%= post.photos.attached? ? '' : 'hidden ' %>flex flex-wrap gap-2">
            <% if post.photos.attached? %>
              <% post.photos.each do |photo| %>
                <div class="relative group" data-photo-wrapper>
                  <%= image_tag photo.variant(resize_to_fill: [80, 80]), class: "w-20 h-20 object-cover rounded-lg border border-gray-200 dark:border-gray-600" %>
                  <button type="button"
                          data-action="photo-upload#removeExisting"
                          data-photo-upload-id-param="<%= photo.id %>"
                          class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-red-500 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition cursor-pointer">&times;</button>
                </div>
              <% end %>
            <% end %>
          </div>

          <div class="flex items-center justify-between">
            <button type="button" data-action="photo-upload#select" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-sf-gold dark:hover:text-sf-gold transition cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
              </svg>
              Add photos
            </button>
            <div class="flex gap-3">
              <button type="button" data-action="post-edit#cancel" class="btn-tertiary py-2.5">Cancel</button>
              <%= f.submit "Save", class: "btn-primary py-2.5" %>
            </div>
          </div>
        <% end %>
        <div data-mention-target="dropdown" class="hidden absolute left-0 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto"></div>
      <% end %>
    </div>
  <% end %>

  <%= render "reactions/reactions", reactable: post %>

  <!-- Replies section -->
  <div class="mt-3 border-t border-sf-sand/20 dark:border-gray-700 pt-3">
    <button type="button" data-action="replies-section#toggle" class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer transition">
      <%= comments.size %> <%= "reply".pluralize(comments.size) %>
    </button>

    <div data-replies-section-target="panel" class="hidden mt-3">
      <!-- Replies list -->
      <div id="post_comments_for_<%= post.id %>" class="space-y-4 mb-4">
        <% top_level_comments.each do |comment| %>
          <%= render local_assigns[:comment_partial], { comment: comment }.merge(local_assigns[:comment_locals] || {}) %>
        <% end %>
        <% if top_level_comments.empty? %>
          <p id="no_comments_placeholder_for_<%= post.id %>" class="text-center text-gray-400 dark:text-gray-500 text-sm py-4">No replies yet.</p>
        <% end %>
      </div>

      <!-- Reply form -->
      <% mention_attrs = { "data-controller": "mention", "data-mention-url-value": mention_searches_path } %>
      <% (local_assigns[:mention_data] || {}).each do |key, value| %>
        <% mention_attrs[:"data-#{key.to_s.tr('_', '-')}"] = value %>
      <% end %>
      <%= tag.div **mention_attrs, class: "relative" do %>
        <%= form_with(
          model: local_assigns[:comment_form_model],
          class: "flex gap-2 items-start",
          data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" }
        ) do |f| %>
          <%= f.hidden_field :body, data: { mention_target: "hidden" } %>
          <div contenteditable="true"
               data-mention-target="input"
               data-action="input->mention#onInput keydown->mention#onKeydown blur->mention#hide paste->mention#onPaste"
               data-placeholder="Add a reply... (@ to mention)"
               class="flex-1 min-h-[80px] border-gray-300 rounded-xl shadow-sm px-4 py-3 text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-sf-gold focus:border-sf-gold border"
               role="textbox"></div>
          <%= f.submit "Reply",
              class: "self-end btn-primary py-2.5" %>
        <% end %>
        <div data-mention-target="dropdown" class="hidden absolute left-0 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto"></div>
      <% end %>
    </div>
  </div>
</div>
