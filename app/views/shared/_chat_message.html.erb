<% if message.system_message? %>
  <div id="<%= dom_id(message) %>" class="flex justify-center py-2">
    <p class="text-xs text-gray-400 dark:text-gray-500 italic"><%= message.body %></p>
  </div>
<% else %>
  <div id="<%= dom_id(message) %>" class="flex items-start gap-3 p-3" data-sender-id="<%= message.user_id %>">
    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-sm font-bold text-sf-black dark:text-white">
      <% if message.user.avatar.attached? %>
        <%= image_tag rails_representation_path(message.user.avatar.variant(:display)), class: "w-8 h-8 rounded-full object-cover" %>
      <% else %>
        <%= message.user.name.first.upcase %>
      <% end %>
    </div>
    <div data-message-bubble class="bg-sf-beige dark:bg-gray-700 rounded-xl px-4 py-2 max-w-[75%]">
      <p data-sender-name class="text-xs font-semibold text-sf-gold mb-1"><%= message.user.name %></p>
      <p class="text-sm text-sf-black dark:text-gray-100"><%= render_with_mentions(message.body) %></p>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= time_ago_in_words(message.created_at) %> ago</p>
    </div>
  </div>
<% end %>
