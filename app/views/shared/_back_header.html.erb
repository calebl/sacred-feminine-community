<div class="flex items-center gap-4 mb-6">
  <%= link_to path, class: "p-2 rounded-lg text-gray-400 hover:text-sf-gold hover:bg-sf-gold/10 dark:hover:bg-gray-700 transition" do %>
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  <% end %>
  <% if local_assigns[:title] %>
    <h1 class="text-2xl font-display font-bold text-sf-black dark:text-white"><%= title %></h1>
  <% end %>
  <%= yield if block_given? %>
</div>
