<div id="<%= dom_id(comment) %>" data-controller="replies-toggle">
  <div class="flex items-start gap-3 p-3 rounded-xl bg-sf-beige/30 dark:bg-gray-700/50">
    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-sm font-bold text-sf-black dark:text-white">
      <% if comment.user.avatar.attached? %>
        <%= image_tag comment.user.avatar.variant(resize_to_fill: [32, 32]), class: "w-8 h-8 rounded-full object-cover" %>
      <% else %>
        <%= comment.user.name.first.upcase %>
      <% end %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-sf-black dark:text-white"><%= comment.user.name %></span>
          <span class="text-xs text-gray-400 dark:text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago</span>
        </div>
        <% if policy(comment).destroy? %>
          <%= button_to group_group_post_group_post_comment_path(group, group_post, comment),
              method: :delete,
              class: "text-xs text-red-400 hover:text-red-600 transition cursor-pointer",
              data: { turbo_confirm: "Delete this comment?" } do %>
            Delete
          <% end %>
        <% end %>
      </div>
      <p class="text-sm text-gray-700 dark:text-gray-300 mt-1 whitespace-pre-wrap"><%= render_with_mentions(comment.body) %></p>
      <div data-controller="reply-form">
        <div class="flex items-center gap-3">
          <button type="button"
                  data-action="reply-form#toggle"
                  class="text-xs text-sf-gold hover:text-sf-gold/80 mt-1 cursor-pointer transition">
            Reply
          </button>
          <span id="reply_count_for_<%= comment.id %>">
            <% if comment.replies.any? %>
              <button type="button"
                      data-action="replies-toggle#toggle"
                      class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 mt-1 cursor-pointer transition">
                <%= pluralize(comment.replies.size, "reply") %>
              </button>
            <% end %>
          </span>
        </div>

        <%# Reply form (hidden by default, toggled by Stimulus) %>
        <div data-reply-form-target="form" class="mt-2 hidden">
          <div data-controller="mention"
               data-mention-url-value="<%= mention_searches_path %>"
               data-mention-group-id-value="<%= group.id %>"
               class="relative">
            <%= form_with(
              model: [group, group_post, GroupPostComment.new],
              class: "flex gap-2 items-start",
              data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset turbo:submit-end->reply-form#hide" }
            ) do |f| %>
              <%= f.hidden_field :parent_id, value: comment.id %>
              <%= f.hidden_field :body, data: { mention_target: "hidden" } %>
              <div contenteditable="true"
                   data-mention-target="input"
                   data-action="input->mention#onInput keydown->mention#onKeydown blur->mention#hide paste->mention#onPaste"
                   data-placeholder="Reply to <%= comment.user.name %>..."
                   class="flex-1 min-h-[60px] border-gray-300 rounded-xl shadow-sm px-4 py-3 text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-sf-gold focus:border-sf-gold border"
                   role="textbox"></div>
              <%= f.submit "Reply",
                  class: "self-end btn-primary py-2 text-sm" %>
            <% end %>
            <div data-mention-target="dropdown" class="hidden absolute left-0 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Nested replies %>
  <div id="replies_for_<%= comment.id %>" data-replies-toggle-target="replies" class="ml-8 border-l-2 border-sf-sand/30 dark:border-gray-600 pl-3 mt-2 space-y-2 hidden">
    <% comment.replies.sort_by(&:created_at).each do |reply| %>
      <%= render "group_post_comments/group_post_comment", comment: reply, group: group, group_post: group_post %>
    <% end %>
  </div>
</div>
