<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-sf-beige to-sf-sand/30 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-display font-bold text-sf-black">Sacred Feminine</h1>
      <p class="text-gray-500 mt-2 font-body">You've been invited to join our community</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-sf-sand/20 p-8">
      <h2 class="text-xl font-display font-semibold text-sf-black mb-6">Accept Your Invitation</h2>

      <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= f.hidden_field :invitation_token, readonly: true %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, autofocus: true,
              class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
              placeholder: "Your full name" %>
        </div>

        <% if f.object.class.require_password_on_accepting %>
          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
                placeholder: "Choose a password" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
                placeholder: "Confirm your password" %>
          </div>
        <% end %>

        <div>
          <%= f.submit "Join the Community",
              class: "w-full btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
