<div class="max-w-md mx-auto px-4 py-8">
  <h1 class="text-2xl font-display font-bold text-sf-black mb-6">Invite a New Member</h1>

  <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm", required: true, placeholder: "Full name" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm", required: true, placeholder: "email@example.com" %>
    </div>

    <div>
      <%= f.submit "Send Invitation", class: "w-full px-6 py-3 bg-sf-gold text-black rounded-xl hover:bg-sf-blue hover:text-white font-semibold transition cursor-pointer shadow-sm text-sm" %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to "Back to Dashboard", admin_dashboard_path, class: "text-sm text-sf-gold hover:text-sf-gold/80 transition" %>
  </div>
</div>
