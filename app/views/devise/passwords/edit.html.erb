<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-sf-beige to-sf-sand/30 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-display font-bold text-sf-black">Sacred Feminine</h1>
      <p class="text-gray-500 mt-2 font-body">Set your new password</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-sf-sand/20 p-8">
      <h2 class="text-xl font-display font-semibold text-sf-black mb-6">Change Password</h2>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= f.hidden_field :reset_password_token %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
              placeholder: "Minimum 6 characters" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-400 mt-1"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
              placeholder: "Retype your password" %>
        </div>

        <div>
          <%= f.submit "Change Password",
              class: "w-full btn-primary" %>
        </div>
      <% end %>

      <div class="mt-6 pt-6 border-t border-sf-sand/20 text-center">
        <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-sm text-sf-gold hover:text-sf-gold/80 transition" %>
      </div>
    </div>
  </div>
</div>
