<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-sf-beige to-sf-sand/30 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-display font-bold text-sf-black">Sacred Feminine</h1>
      <p class="text-gray-500 mt-2 font-body">Reset your password</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-sf-sand/20 p-8">
      <h2 class="text-xl font-display font-semibold text-sf-black mb-6">Forgot Password</h2>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
              placeholder: "your@email.com" %>
        </div>

        <div>
          <%= f.submit "Send Reset Instructions",
              class: "w-full px-6 py-3 bg-sf-gold text-black rounded-xl hover:bg-sf-blue hover:text-white font-semibold transition cursor-pointer shadow-sm text-sm" %>
        </div>
      <% end %>

      <div class="mt-6 pt-6 border-t border-sf-sand/20 text-center">
        <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-sm text-sf-gold hover:text-sf-gold/80 transition" %>
      </div>
    </div>
  </div>
</div>
