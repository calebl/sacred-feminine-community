<div class="min-h-screen flex bg-gradient-to-br from-sf-beige to-sf-sand/30">
  <!-- Left: Logo -->
  <div class="hidden lg:flex lg:w-1/2 items-center justify-center bg-[#f8f8f8]">
    <%= image_tag "logo.png", alt: "Sacred Feminine", class: "w-80 h-80" %>
  </div>

  <!-- Right: Form -->
  <div class="w-full lg:w-1/2 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <!-- Mobile logo -->
      <div class="lg:hidden text-center mb-8">
        <%= image_tag "logo.png", alt: "Sacred Feminine", class: "w-24 h-24 mx-auto mb-4" %>
        <h1 class="text-3xl font-display font-bold text-sf-black">Sacred Feminine</h1>
        <p class="text-gray-500 mt-2 font-body">Welcome back to your community</p>
      </div>

      <!-- Desktop heading -->
      <div class="hidden lg:block mb-8">
        <h1 class="text-3xl font-display font-bold text-sf-black">Sacred Feminine</h1>
        <p class="text-gray-500 mt-2 font-body">Welcome back to your community</p>
      </div>

      <div class="bg-white rounded-2xl shadow-lg border border-sf-sand/20 p-8">
        <h2 class="text-xl font-display font-semibold text-sf-black mb-6">Sign In</h2>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
                placeholder: "your@email.com" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full rounded-xl border-gray-300 shadow-sm focus:ring-sf-gold focus:border-sf-gold px-4 py-3 text-sm",
                placeholder: "Your password" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "rounded border-gray-300 text-sf-gold focus:ring-sf-gold" %>
              <%= f.label :remember_me, class: "text-sm text-gray-600" %>
            </div>
          <% end %>

          <div>
            <%= f.submit "Sign In",
                class: "w-full btn-primary" %>
          </div>
        <% end %>

        <div class="mt-6 pt-6 border-t border-sf-sand/20 text-center space-y-2">
          <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-sm text-sf-gold hover:text-sf-gold/80 transition" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
