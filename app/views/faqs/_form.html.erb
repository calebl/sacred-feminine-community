<%= form_with(model: faq, class: "space-y-6") do |f| %>
  <% if faq.errors.any? %>
    <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
      <% faq.errors.full_messages.each do |message| %>
        <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :question, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :question, class: "w-full", required: true %>
  </div>

  <div>
    <%= f.label :answer, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :answer, rows: 5, class: "w-full", required: true %>
  </div>

  <div>
    <%= f.label :position, "Display Order", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.number_field :position, class: "w-full", min: 0 %>
    <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Lower numbers appear first.</p>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "rounded border-gray-300 text-sf-gold focus:ring-sf-gold" %>
    <%= f.label :active, "Visible to members", class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
  </div>

  <div>
    <%= f.submit class: "w-full btn-primary" %>
  </div>
<% end %>
