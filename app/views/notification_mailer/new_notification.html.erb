<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; max-width: 520px; margin: 0 auto; padding: 32px 24px; color: #1f2937;">
  <h1 style="font-size: 20px; font-weight: 600; margin: 0 0 12px;">
    <%= @notification.title %>
  </h1>

  <% if @notification.body.present? %>
    <p style="font-size: 16px; line-height: 1.5; margin: 0 0 24px;">
      <%= @notification.body %>
    </p>
  <% end %>

  <p style="margin: 0 0 32px;">
    <%= link_to "View in app", @notification_url,
          style: "display: inline-block; padding: 10px 20px; background: #b08968; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600;" %>
  </p>

  <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 24px 0;">

  <p style="font-size: 12px; color: #6b7280; margin: 0;">
    You're receiving this email because notifications are enabled for your account.
    <%= link_to "Manage notification settings", @settings_url, style: "color: #6b7280;" %>.
  </p>
</div>
