<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sacred Feminine Community" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sacred Feminine">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" crossorigin="" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" crossorigin="" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/favicon.ico" sizes="32x32">
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="icon" href="/icon-512.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "cropper", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script nonce="<%= content_security_policy_nonce %>">
      if (localStorage.getItem("darkMode") === "true" ||
          (!localStorage.getItem("darkMode") && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>

  <body class="bg-sf-beige/30 dark:bg-gray-900 text-sf-black dark:text-gray-100 font-sans min-h-screen flex flex-col transition-colors" data-current-conversation-id="<%= yield(:current_conversation_id) %>">
    <%= render "shared/impersonation_banner" if user_signed_in? && impersonating? %>
    <% if user_signed_in? %>
      <%= turbo_stream_from current_user, :dm_notifications %>
      <div id="dm_notifications" data-controller="dm-notification"
           class="fixed top-20 right-4 max-md:top-4 max-md:right-0 max-md:left-0 max-md:px-4 z-[60] flex flex-col gap-3 pointer-events-none"></div>

      <!-- Desktop top navbar -->
      <nav class="bg-white dark:bg-gray-800 border-b border-sf-sand/20 dark:border-gray-700 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16 items-center">
            <div class="flex items-center">
              <%= link_to authenticated_root_path, class: "flex items-center gap-2" do %>
                <%= image_tag "logo.png", alt: "Sacred Feminine", class: "h-8 w-8" %>
                <span class="text-xl font-display font-bold text-sf-black dark:text-white">Sacred Feminine</span>
              <% end %>
            </div>

            <div class="hidden md:flex items-center gap-1">
              <% home_active = content_for?(:content) || request.path == '/' %>
              <%= link_to "Home", authenticated_root_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{home_active ? 'bg-sf-gold/10 text-sf-gold' : 'text-gray-600 dark:text-gray-300 hover:bg-sf-gold/10 dark:hover:bg-gray-700 hover:text-sf-gold'}" %>
              <%= link_to "Cohorts", cohorts_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{request.path == '/cohorts' ? 'bg-sf-gold/10 text-sf-gold' : 'text-gray-600 dark:text-gray-300 hover:bg-sf-gold/10 dark:hover:bg-gray-700 hover:text-sf-gold'}" %>
              <%= link_to "Messages", conversations_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/conversations') ? 'bg-sf-gold/10 text-sf-gold' : 'text-gray-600 dark:text-gray-300 hover:bg-sf-gold/10 dark:hover:bg-gray-700 hover:text-sf-gold'}" %>
              <% if current_user.admin? %>
                <%= link_to "Admin", admin_dashboard_path, class: "px-4 py-2 rounded-lg text-sm font-medium text-sf-gold hover:bg-sf-gold/10 transition-colors" %>
              <% end %>

              <div class="w-px h-6 bg-sf-sand/30 dark:bg-gray-600 mx-2"></div>

              <% unread_total = total_unread_count(current_user) %>
              <%= link_to notifications_path, class: "relative p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-sf-gold/10 dark:hover:bg-gray-700 transition-colors #{request.path == '/notifications' ? 'bg-sf-gold/10 text-sf-gold' : ''}", title: "Notifications" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                </svg>
                <% if unread_total > 0 %>
                  <span class="absolute -top-1 -right-1 bg-sf-red text-white text-[10px] font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1"><%= unread_total > 99 ? "99+" : unread_total %></span>
                <% end %>
              <% end %>

              <%= link_to edit_profile_path(current_user), class: "p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-sf-gold/10 dark:hover:bg-gray-700 transition-colors", title: "Profile" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <% end %>

              <%= button_to destroy_user_session_path, method: :delete, class: "p-2 rounded-lg text-gray-400 dark:text-gray-500 hover:bg-sf-gold/10 dark:hover:bg-gray-700 hover:text-sf-red cursor-pointer transition-colors", title: "Sign out" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              <% end %>
            </div>

            <!-- Mobile: dark mode toggle + sign out -->
            <div class="md:hidden flex items-center gap-1">
              <%= button_to destroy_user_session_path, method: :delete, class: "p-3 rounded-lg text-gray-400 hover:text-sf-red cursor-pointer", title: "Sign out" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              <% end %>
            </div>
          </div>
        </div>
      </nav>

      <!-- Mobile bottom nav -->
      <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-800 border-t border-sf-sand/20 dark:border-gray-700 z-50 safe-area-bottom shadow-[0_-2px_10px_rgba(0,0,0,0.05)]">
        <div class="flex justify-around py-1">
          <%= link_to authenticated_root_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{home_active ? 'text-sf-gold' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Home
          <% end %>
          <%= link_to groups_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path.start_with?('/groups') ? 'text-sf-gold' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Groups
          <% end %>
          <%= link_to conversations_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path.start_with?('/conversations') ? 'text-sf-gold' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            Messages
          <% end %>
          <%= link_to notifications_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors relative #{request.path == '/notifications' ? 'text-sf-gold' : 'text-gray-400 dark:text-gray-500'}" do %>
            <div class="relative">
              <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
              <% if unread_total > 0 %>
                <span class="absolute -top-1 -right-2 bg-sf-red text-white text-[9px] font-bold rounded-full min-w-[14px] h-[14px] flex items-center justify-center px-0.5"><%= unread_total > 99 ? "99+" : unread_total %></span>
              <% end %>
            </div>
            Alerts
          <% end %>
          <%= link_to edit_profile_path(current_user), class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path.start_with?('/profiles') ? 'text-sf-gold' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Profile
          <% end %>
        </div>
      </nav>
    <% end %>

    <%# Flash messages hidden — keeping controller notices/alerts intact for now %>

    <main class="flex-1 pb-20 md:pb-0">
      <%= content_for?(:content) ? yield(:content) : yield %>
    </main>

    <%# Custom confirm dialog - replaces browser native confirm() %>
    <div data-controller="confirm-dialog" id="confirm-dialog">
      <dialog
        data-confirm-dialog-target="dialog"
        data-action="click->confirm-dialog#backdropClick cancel->confirm-dialog#handleCancel"
        class="backdrop:bg-black/50 backdrop:backdrop-blur-sm bg-transparent p-0 m-auto max-w-md w-[calc(100%-2rem)] opacity-0 scale-95 data-[open]:opacity-100 data-[open]:scale-100 transition-all duration-200 ease-out"
      >
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-sf-sand/20 dark:border-gray-700 p-6">
          <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 rounded-full bg-sf-red/10">
            <svg class="w-6 h-6 text-sf-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>

          <h3 class="text-lg font-display font-semibold text-sf-black dark:text-white text-center mb-2">
            Are you sure?
          </h3>

          <p data-confirm-dialog-target="message"
             class="text-sm text-gray-600 dark:text-gray-400 text-center mb-6">
          </p>

          <div class="flex gap-3">
            <button
              data-action="confirm-dialog#cancel"
              class="flex-1 px-4 py-2.5 rounded-xl border border-sf-sand/40 dark:border-gray-600 text-sm font-semibold text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition cursor-pointer"
            >
              Cancel
            </button>
            <button
              data-action="confirm-dialog#confirm"
              class="flex-1 px-4 py-2.5 rounded-xl bg-sf-red text-white text-sm font-semibold hover:bg-sf-red/90 transition cursor-pointer"
            >
              Confirm
            </button>
          </div>
        </div>
      </dialog>
    </div>
  </body>
</html>
