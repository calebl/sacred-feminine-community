<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sacred Feminine Community" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sacred Feminine">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script nonce="<%= content_security_policy_nonce %>">
      if (localStorage.getItem("darkMode") === "true" ||
          (!localStorage.getItem("darkMode") && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>

  <body class="bg-sf-beige/30 dark:bg-gray-900 text-sf-black dark:text-gray-100 font-sans min-h-screen flex flex-col transition-colors">
    <%= render "shared/impersonation_banner" if user_signed_in? && impersonating? %>
    <% if user_signed_in? %>
      <!-- Desktop top navbar -->
      <nav class="bg-white dark:bg-gray-800 border-b border-sf-sand/20 dark:border-gray-700 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16 items-center">
            <div class="flex items-center">
              <%= link_to authenticated_root_path, class: "flex items-center gap-2" do %>
                <%= image_tag "logo.png", alt: "Sacred Feminine", class: "h-8 w-8" %>
                <span class="text-xl font-display font-bold text-sf-black dark:text-white">Sacred Feminine</span>
              <% end %>
            </div>

            <div class="hidden md:flex items-center gap-1">
              <%= link_to "Map", map_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{request.path == '/map' ? 'bg-sf-red/10 text-sf-red' : 'text-gray-600 dark:text-gray-300 hover:bg-sf-sand/20 dark:hover:bg-gray-700 hover:text-sf-red'}" %>
              <%= link_to "My Cohorts", cohorts_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/cohorts') ? 'bg-sf-red/10 text-sf-red' : 'text-gray-600 dark:text-gray-300 hover:bg-sf-sand/20 dark:hover:bg-gray-700 hover:text-sf-red'}" %>
              <%= link_to "Messages", conversations_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/conversations') ? 'bg-sf-red/10 text-sf-red' : 'text-gray-600 dark:text-gray-300 hover:bg-sf-sand/20 dark:hover:bg-gray-700 hover:text-sf-red'}" %>
              <% if current_user.admin? %>
                <%= link_to "Admin", admin_dashboard_path, class: "px-4 py-2 rounded-lg text-sm font-medium text-sf-gold hover:bg-sf-gold/10 transition-colors" %>
              <% end %>

              <div class="w-px h-6 bg-sf-sand/30 dark:bg-gray-600 mx-2"></div>

              <!-- Dark mode toggle -->
              <button data-controller="dark-mode" data-action="click->dark-mode#toggle" class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-sf-sand/20 dark:hover:bg-gray-700 transition-colors" title="Toggle dark mode">
                <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/></svg>
                <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
              </button>

              <%= link_to edit_profile_path(current_user), class: "p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-sf-sand/20 dark:hover:bg-gray-700 transition-colors", title: "Profile" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <% end %>

              <%= button_to destroy_user_session_path, method: :delete, class: "p-2 rounded-lg text-gray-400 dark:text-gray-500 hover:bg-sf-sand/20 dark:hover:bg-gray-700 hover:text-sf-red transition-colors", title: "Sign out" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              <% end %>
            </div>

            <!-- Mobile: dark mode toggle + sign out -->
            <div class="md:hidden flex items-center gap-1">
              <button data-controller="dark-mode" data-action="click->dark-mode#toggle" class="p-3 rounded-lg text-gray-500 dark:text-gray-400" title="Toggle dark mode">
                <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/></svg>
                <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
              </button>

              <%= button_to destroy_user_session_path, method: :delete, class: "p-3 rounded-lg text-gray-400 hover:text-sf-red", title: "Sign out" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              <% end %>
            </div>
          </div>
        </div>
      </nav>

      <!-- Mobile bottom nav -->
      <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-800 border-t border-sf-sand/20 dark:border-gray-700 z-50 safe-area-bottom shadow-[0_-2px_10px_rgba(0,0,0,0.05)]">
        <div class="flex justify-around py-1">
          <%= link_to map_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path == '/map' ? 'text-sf-red' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Map
          <% end %>
          <%= link_to cohorts_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path.start_with?('/cohorts') ? 'text-sf-red' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Cohorts
          <% end %>
          <%= link_to conversations_path, class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path.start_with?('/conversations') ? 'text-sf-red' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            Messages
          <% end %>
          <%= link_to edit_profile_path(current_user), class: "flex flex-col items-center min-w-[64px] min-h-[48px] justify-center text-xs transition-colors #{request.path.start_with?('/profiles') ? 'text-sf-red' : 'text-gray-400 dark:text-gray-500'}" do %>
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Profile
          <% end %>
        </div>
      </nav>
    <% end %>

    <% if notice.present? || alert.present? %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <% if notice.present? %>
          <div class="rounded-xl p-4 bg-sf-green/10 text-green-800 dark:text-green-300 border border-sf-green/20 mb-2">
            <p class="text-sm font-medium"><%= notice %></p>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="rounded-xl p-4 bg-sf-red/10 text-red-800 dark:text-red-300 border border-sf-red/20 mb-2">
            <p class="text-sm font-medium"><%= alert %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="flex-1 pb-20 md:pb-0">
      <%= yield %>
    </main>
  </body>
</html>
