<%= render layout: "shared/post_show", locals: {
  post: @post,
  editing: @editing,
  comments: @comments,
  new_comment: @new_comment,
  back_path: group_path(@group, tab: :feed),
  back_label: "Back to #{@group.name}",
  edit_path: edit_group_group_post_path(@group, @post),
  pin_path: group_group_post_pin_path(@group, @post),
  post_path: group_group_post_path(@group, @post),
  form_url: group_group_post_path(@group, @post),
  form_extras: { group_id: @group.id },
  comment_form_model: [@group, @post, @new_comment],
  comments_count: @post.group_post_comments.count,
  mention_data: { "mention-group-id-value": @group.id }
} do %>
  <% @comments.each do |comment| %>
    <%= render "group_post_comments/group_post_comment", comment: comment, group: @group, group_post: @post %>
  <% end %>
<% end %>
