<div id="<%= dom_id(chat_message) %>" class="flex items-start gap-3 p-3">
  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-sm font-bold text-sf-black dark:text-white">
    <% if chat_message.user.avatar.attached? %>
      <%= image_tag chat_message.user.avatar.variant(resize_to_fill: [32, 32]), class: "w-8 h-8 rounded-full object-cover" %>
    <% else %>
      <%= chat_message.user.name.first.upcase %>
    <% end %>
  </div>
  <div class="bg-sf-beige dark:bg-gray-700 rounded-xl px-4 py-2 max-w-[75%]">
    <p class="text-xs font-semibold text-sf-gold mb-1"><%= chat_message.user.name %></p>
    <p class="text-sm text-sf-black dark:text-gray-100"><%= chat_message.body %></p>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= time_ago_in_words(chat_message.created_at) %> ago</p>
  </div>
</div>
