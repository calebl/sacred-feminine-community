<div class="max-w-2xl mx-auto px-4 py-8">
  <%= render "shared/back_header", path: cohort_path(@cohort), title: "Edit Cohort" %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8">
    <%= render "form", cohort: @cohort %>
    <div class="mt-6 pt-6 border-t border-sf-sand/20 dark:border-gray-700">
      <%= button_to "Delete Cohort", cohort_path(@cohort), method: :delete,
          class: "text-sm text-red-500 hover:text-red-700",
          data: { turbo_confirm: "Are you sure? This will delete the cohort and all its messages." } %>
    </div>
  </div>
</div>
