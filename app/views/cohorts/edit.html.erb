<div class="max-w-2xl mx-auto px-4 py-8">
  <%= link_to cohort_path(@cohort), class: "inline-flex items-center text-sm text-gray-500 hover:text-sf-gold transition mb-4" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    Back to Cohort
  <% end %>
  <h1 class="text-2xl font-display font-bold text-sf-black dark:text-white mb-6">Edit Cohort</h1>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8">
    <%= render "form", cohort: @cohort %>
    <div class="mt-6 pt-6 border-t border-sf-sand/20 dark:border-gray-700">
      <%= button_to "Delete Cohort", cohort_path(@cohort), method: :delete,
          class: "text-sm text-red-500 hover:text-red-700",
          data: { turbo_confirm: "Are you sure? This will delete the cohort and all its messages." } %>
    </div>
  </div>
</div>
