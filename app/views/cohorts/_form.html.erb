<%= form_with(model: cohort, class: "space-y-6") do |f| %>
  <% if cohort.errors.any? %>
    <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
      <% cohort.errors.full_messages.each do |message| %>
        <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :name, class: "w-full", required: true %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full" %>
  </div>

  <div>
    <%= f.label :retreat_location, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :retreat_location, class: "w-full" %>
  </div>

  <div>
    <%= f.label :retreat_date, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.date_field :retreat_date, class: "w-full" %>
  </div>

  <div>
    <%= f.label :header_image, "Header Image", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <% if cohort.header_image.attached? %>
      <div class="mb-3 rounded-xl overflow-hidden">
        <%= image_tag cohort.header_image.variant(resize_to_limit: [800, 300]), class: "w-full h-32 object-cover rounded-xl" %>
      </div>
    <% end %>
    <%= f.file_field :header_image, accept: "image/*", class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-sf-sand/30 file:text-sf-black hover:file:bg-sf-sand/50 dark:file:bg-gray-700 dark:file:text-white" %>
    <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Upload a group photo or banner image.</p>
  </div>

  <div>
    <%= f.submit class: "w-full px-6 py-3 bg-sf-gold text-black rounded-xl hover:bg-sf-blue hover:text-white font-semibold transition cursor-pointer shadow-sm text-sm" %>
  </div>
<% end %>
