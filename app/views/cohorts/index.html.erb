<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white">My Cohorts</h1>
    <% if current_user.admin? %>
      <%= link_to "New Cohort", new_cohort_path, class: "px-5 py-2.5 bg-sf-gold text-black rounded-xl hover:bg-sf-blue hover:text-white text-sm font-semibold transition shadow-sm" %>
    <% end %>
  </div>

  <% if @cohorts.any? %>
    <div class="space-y-4">
      <% @cohorts.each do |cohort| %>
        <%= link_to cohort_path(cohort), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-hidden hover:shadow-md transition" do %>
          <% if cohort.header_image.attached? %>
            <%= image_tag cohort.header_image.variant(resize_to_limit: [800, 200]), class: "w-full h-32 object-cover" %>
          <% else %>
            <div class="w-full h-32 bg-gradient-to-br from-sf-sand/20 to-sf-gold/10 dark:from-gray-700 dark:to-gray-800 flex items-center justify-center">
              <svg class="w-8 h-8 text-sf-gold/30 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
              </svg>
            </div>
          <% end %>
          <div class="p-6">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-display font-semibold text-sf-black dark:text-white"><%= cohort.name %></h2>
                <% if cohort.retreat_location.present? %>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= cohort.retreat_location %></p>
                <% end %>
                <% if cohort.retreat_date.present? %>
                  <p class="text-sm text-gray-400 dark:text-gray-500 mt-1"><%= cohort.retreat_date.strftime("%B %Y") %></p>
                <% end %>
              </div>
              <div class="text-right">
                <p class="text-2xl font-bold text-sf-gold"><%= cohort.members.size %></p>
                <p class="text-xs text-gray-400 dark:text-gray-500">members</p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-400 dark:text-gray-500">
      <p class="text-lg">No cohorts yet.</p>
      <p class="text-sm mt-2">You'll see your retreat groups here once you're added to a cohort.</p>
    </div>
  <% end %>
</div>
