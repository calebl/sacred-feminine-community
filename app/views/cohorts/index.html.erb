<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white">Cohorts</h1>
    <% if current_user.admin? %>
      <%= link_to "New Cohort", new_cohort_path, class: "btn-primary px-5 py-2.5" %>
    <% end %>
  </div>

  <% if @cohorts.any? %>
    <div class="space-y-4">
      <% @cohorts.each do |cohort| %>
        <%= render "cohort_card", cohort: cohort %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-400 dark:text-gray-500">
      <p class="text-lg">No cohorts yet.</p>
      <p class="text-sm mt-2">You'll see retreat groups here once cohorts are created.</p>
    </div>
  <% end %>
</div>
