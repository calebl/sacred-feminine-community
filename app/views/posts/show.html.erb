<%= render layout: "shared/post_show", locals: {
  post: @post,
  editing: @editing,
  comments: @comments,
  new_comment: @new_comment,
  back_path: cohort_path(@cohort, tab: :feed),
  back_label: "Back to #{@cohort.name}",
  edit_path: edit_cohort_post_path(@cohort, @post),
  pin_path: cohort_post_pin_path(@cohort, @post),
  post_path: cohort_post_path(@cohort, @post),
  form_url: cohort_post_path(@cohort, @post),
  form_extras: { cohort_id: @cohort.id },
  comment_form_model: [@cohort, @post, @new_comment],
  comments_count: @post.post_comments.count,
  mention_data: { "mention-cohort-id-value": @cohort.id }
} do %>
  <% @comments.each do |comment| %>
    <%= render "post_comments/post_comment", comment: comment, cohort: @cohort, post: @post %>
  <% end %>
<% end %>
