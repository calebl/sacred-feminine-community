<div class="max-w-5xl mx-auto px-4 py-8" data-controller="email-preview">
  <%= render "shared/back_header", path: (@locked_cohort ? cohort_path(@locked_cohort) : admin_dashboard_path), title: "Invite Cohort" %>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8">
      <%= form_with url: admin_bulk_invitations_path, method: :post, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :cohort_id, "Cohort", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <% if @locked_cohort %>
            <%= hidden_field_tag :cohort_id, @locked_cohort.id %>
            <%= hidden_field_tag :locked_cohort, "1" %>
            <p class="text-sf-black dark:text-white font-medium"><%= @locked_cohort.name %></p>
          <% else %>
            <%= f.select :cohort_id, @cohorts.map { |c| [c.name, c.id] }, { prompt: "Select a cohort" }, { class: "w-full", required: true } %>
          <% end %>
        </div>

        <div>
          <%= f.label :emails, "Email Addresses", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_area :emails, rows: 6, class: "w-full", required: true, placeholder: "Enter one email per line, or separate with commas\n\njane@example.com\nsarah@example.com\nanna@example.com" %>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">One email per line, or separated by commas or semicolons.</p>
        </div>

        <div>
          <%= f.label :invitation_message, "Invite Message", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_area :invitation_message, value: @previous_message, rows: 4, class: "w-full", placeholder: "Add a personal message to replace the default invitation text...",
              data: { email_preview_target: "message", action: "input->email-preview#update" } %>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">This message will replace the default text in the invitation email.</p>
        </div>

        <div>
          <%= f.submit "Send Invitations", class: "w-full btn-primary" %>
        </div>
      <% end %>
    </div>

    <div class="xl:sticky xl:top-24">
      <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Email Preview</h2>
      <div data-email-preview-target="preview" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8 text-sm text-gray-700 dark:text-gray-300 space-y-4">
        <%= render "shared/invitation_email_body",
            recipient_name: nil,
            custom_message: nil,
            accept_url: nil,
            preview: true %>
      </div>
    </div>
  </div>
</div>
