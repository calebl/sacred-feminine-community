<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to admin_dashboard_path, class: "p-2 rounded-lg text-gray-400 hover:text-sf-red hover:bg-sf-sand/20 dark:hover:bg-gray-700 transition" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white">Removed Users</h1>
  </div>

  <% if @users.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-hidden">
      <table class="min-w-full divide-y divide-sf-sand/20 dark:divide-gray-700">
        <thead class="bg-sf-beige/30 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Removed</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-sf-sand/10 dark:divide-gray-700">
          <% @users.each do |user| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-400 dark:text-gray-500"><%= user.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400 dark:text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400 dark:text-gray-500"><%= time_ago_in_words(user.discarded_at) %> ago</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= button_to "Restore",
                    admin_user_path(user),
                    method: :patch,
                    class: "text-sf-blue hover:text-sf-blue/80 font-medium text-sm transition-colors cursor-pointer",
                    data: { turbo_confirm: "Restore #{user.name}? They will be able to sign in again." } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-400 dark:text-gray-500">
      <p class="text-lg">No removed users.</p>
    </div>
  <% end %>
</div>
