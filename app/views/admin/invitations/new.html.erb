<div class="max-w-md mx-auto px-4 py-8">
  <h1 class="text-2xl font-display font-bold text-sf-black dark:text-white mb-6">Invite a New Member</h1>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8">
    <%= form_for(resource, as: resource_name, url: user_invitation_path, html: { method: :post, class: "space-y-6" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
          <% resource.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "w-full", required: true, placeholder: "Full name" %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.email_field :email, class: "w-full", required: true, placeholder: "email@example.com" %>
      </div>

      <div>
        <%= f.submit "Send Invitation", class: "w-full px-6 py-3 bg-sf-gold text-black rounded-xl hover:bg-sf-blue hover:text-white font-semibold transition cursor-pointer shadow-sm text-sm" %>
      </div>
    <% end %>
  </div>

  <div class="mt-4">
    <%= link_to "Back to Dashboard", admin_dashboard_path, class: "text-sm text-sf-gold hover:text-sf-gold/80 transition" %>
  </div>
</div>
