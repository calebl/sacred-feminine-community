<div class="max-w-md mx-auto px-4 py-8">
  <h1 class="text-2xl font-display font-bold text-sf-black dark:text-white mb-6">Invite a New Member</h1>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8"
       data-controller="invite-form">
    <%= form_for(resource, as: resource_name, url: user_invitation_path, html: { method: :post, class: "space-y-6", data: { invite_form_target: "form", dashboard_url: admin_dashboard_path } }) do |f| %>
      <% if resource.errors.any? %>
        <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
          <% resource.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "w-full", required: true, placeholder: "Full name" %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.email_field :email, class: "w-full", required: true, placeholder: "email@example.com" %>
      </div>

      <% if @cohorts.any? %>
        <div>
          <p class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Add to Cohorts</p>
          <div class="space-y-2 max-h-48 overflow-y-auto rounded-xl border border-sf-sand/20 dark:border-gray-600 p-3">
            <% @cohorts.each do |cohort| %>
              <label class="flex items-center gap-2 cursor-pointer">
                <%= check_box_tag "user[invited_cohort_ids][]", cohort.id, false, id: "cohort_#{cohort.id}", class: "rounded border-gray-300 dark:border-gray-600 text-sf-gold focus:ring-sf-gold" %>
                <span class="text-sm text-gray-700 dark:text-gray-300"><%= cohort.name %></span>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="flex gap-3">
        <%= f.submit "Send Invitation Email", class: "flex-1 btn-primary" %>
        <button type="button"
                data-action="invite-form#copyLink"
                class="flex-1 px-6 py-3 bg-sf-gold/10 text-sf-gold rounded-xl hover:bg-sf-gold hover:text-white font-semibold transition shadow-sm text-sm cursor-pointer">
          Copy Invite Link
        </button>
      </div>
    <% end %>
  </div>

  <div class="mt-4">
    <%= link_to "Back to Dashboard", admin_dashboard_path, class: "text-sm text-sf-gold hover:text-sf-gold/80 transition" %>
  </div>
</div>
