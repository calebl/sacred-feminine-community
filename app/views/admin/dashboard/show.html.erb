<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white mb-6">Admin Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700">
      <p class="text-3xl font-bold text-sf-gold"><%= @users_count %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Active Users</p>
    </div>
    <div class="p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700">
      <p class="text-3xl font-bold text-sf-gold"><%= @cohorts_count %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Cohorts</p>
    </div>
    <div class="p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700">
      <p class="text-3xl font-bold text-sf-blue"><%= @pending_invitations_count %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Pending Invitations</p>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= link_to new_user_invitation_path, class: "inline-flex items-center gap-2 btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Invite New Member
    <% end %>

    <%= link_to admin_releases_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 font-semibold transition shadow-sm text-sm" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Changelog
    <% end %>

    <% if @removed_users_count > 0 %>
      <%= link_to admin_users_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 font-semibold transition shadow-sm text-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
        Removed Users (<%= @removed_users_count %>)
      <% end %>
    <% end %>
  </div>

  <% if @admin_users.present? %>
    <div class="mt-8">
      <h2 class="text-xl font-display font-semibold text-sf-black dark:text-white mb-4">Admins</h2>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-x-auto">
        <table class="min-w-full divide-y divide-sf-sand/20 dark:divide-gray-700">
          <thead class="bg-sf-beige/30 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-sf-sand/10 dark:divide-gray-700">
            <% @admin_users.each do |user| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium"><%= link_to user.name, profile_path(user), class: "text-sf-black dark:text-white hover:text-sf-red transition" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400"><%= user.email %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <div class="flex items-center gap-3">
                    <% if user != current_user %>
                      <%= button_to "Make Attendee",
                          admin_user_role_path(user),
                          method: :patch,
                          class: "text-sf-blue hover:text-sf-blue/80 font-medium text-sm transition-colors cursor-pointer",
                          data: { turbo_confirm: "Remove admin privileges from #{user.name}?" } %>
                      <%= button_to "Remove",
                          admin_user_path(user),
                          method: :delete,
                          class: "text-sf-red hover:text-sf-red/80 font-medium text-sm transition-colors cursor-pointer",
                          data: { turbo_confirm: "Remove #{user.name}? They will no longer be able to sign in." } %>
                    <% end %>
                    <% if Rails.env.local? && user != current_user %>
                      <%= button_to "Impersonate", admin_impersonation_path, params: { user_id: user.id },
                          method: :post,
                          class: "text-sf-gold hover:text-sf-gold/80 font-medium text-sm transition-colors cursor-pointer" %>
                    <% else %>
                      <span class="text-gray-400 text-sm italic">Current user</span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @pending_users.present? %>
    <div class="mt-8">
      <h2 class="text-xl font-display font-semibold text-sf-black dark:text-white mb-4">Invited Users</h2>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-x-auto">
        <table class="min-w-full divide-y divide-sf-sand/20 dark:divide-gray-700">
          <thead class="bg-sf-beige/30 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Invited</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-sf-sand/10 dark:divide-gray-700">
            <% @pending_users.each do |user| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-sf-black dark:text-white"><%= user.name %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400"><%= user.email %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400"><%= time_ago_in_words(user.invitation_sent_at || user.created_at) %> ago</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <div class="flex items-center gap-3">
                    <button type="button"
                        data-controller="clipboard"
                        data-clipboard-url-value="<%= admin_user_invite_link_path(user) %>"
                        data-clipboard-confirm-value="This will generate a new invite link and invalidate the one previously sent via email. Continue?"
                        data-action="click->clipboard#copy"
                        class="text-sf-gold hover:text-sf-gold/80 font-medium text-sm transition-colors cursor-pointer">
                      Copy Invite Link
                    </button>
                    <%= button_to "Cancel Invite",
                        admin_user_path(user),
                        method: :delete,
                        class: "text-sf-red hover:text-sf-red/80 font-medium text-sm transition-colors cursor-pointer",
                        data: { turbo_confirm: "Cancel invitation for #{user.email}? This will permanently delete the invitation." } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @active_users.present? %>
    <div class="mt-8">
      <h2 class="text-xl font-display font-semibold text-sf-black dark:text-white mb-4">Users</h2>
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-x-auto">
        <table class="min-w-full divide-y divide-sf-sand/20 dark:divide-gray-700">
          <thead class="bg-sf-beige/30 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-sf-sand/10 dark:divide-gray-700">
            <% @active_users.each do |user| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium"><%= link_to user.name, profile_path(user), class: "text-sf-black dark:text-white hover:text-sf-red transition" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400"><%= user.email %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <div class="flex items-center gap-3">
                    <%= button_to "Make Admin",
                        admin_user_role_path(user),
                        method: :patch,
                        class: "text-sf-gold hover:text-sf-gold/80 font-medium text-sm transition-colors cursor-pointer",
                        data: { turbo_confirm: "Make #{user.name} an admin?\n\nAdmins can:\n• Invite and remove members\n• Restore removed members\n• Change user roles\n• Access the admin dashboard" } %>
                    <%= button_to "Remove",
                        admin_user_path(user),
                        method: :delete,
                        class: "text-sf-red hover:text-sf-red/80 font-medium text-sm transition-colors cursor-pointer",
                        data: { turbo_confirm: "Remove #{user.name}? They will no longer be able to sign in." } %>
                    <% if Rails.env.local? %>
                      <%= button_to "Impersonate", admin_impersonation_path, params: { user_id: user.id },
                          method: :post,
                          class: "text-sf-gold hover:text-sf-gold/80 font-medium text-sm transition-colors cursor-pointer" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
