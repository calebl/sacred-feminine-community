<%= form_with(model: [:admin, announcement], class: "space-y-6") do |f| %>
  <% if announcement.errors.any? %>
    <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
      <% announcement.errors.full_messages.each do |message| %>
        <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :title, class: "w-full", required: true %>
  </div>

  <div>
    <%= f.label :body, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :body, rows: 5, class: "w-full", required: true %>
  </div>

  <div>
    <%= f.label :published_at, "Go Live Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.datetime_local_field :published_at, class: "w-full" %>
    <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Set a future date to schedule when this announcement becomes visible. Leave blank to go live immediately when activated.</p>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "rounded border-gray-300 text-sf-gold focus:ring-sf-gold" %>
    <%= f.label :active, "Make this the active announcement", class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <p class="text-xs text-gray-400 dark:text-gray-500 ml-1">(activating will deactivate any other announcement)</p>
  </div>

  <div>
    <%= f.submit class: "w-full btn-primary" %>
  </div>
<% end %>
