<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white">Announcements</h1>
    <%= link_to new_admin_announcement_path, class: "inline-flex items-center gap-2 btn-primary px-5 py-2.5" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      New Announcement
    <% end %>
  </div>

  <%= link_to "Back to Admin Dashboard", admin_dashboard_path, class: "text-sm text-sf-blue hover:underline mb-6 inline-block" %>

  <% if @announcements.any? %>
    <div class="space-y-4">
      <% @announcements.each do |announcement| %>
        <div class="p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <h2 class="text-lg font-display font-semibold text-sf-black dark:text-white"><%= announcement.title %></h2>
                <% if announcement.scheduled? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">Scheduled</span>
                <% elsif announcement.active? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">Live</span>
                <% end %>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
                By <%= announcement.creator.name %> &middot;
                <% if announcement.scheduled? %>
                  Goes live <%= announcement.published_at.strftime("%B %d, %Y at %I:%M %p") %>
                <% elsif announcement.published_at %>
                  <%= announcement.published_at.strftime("%B %d, %Y") %>
                <% else %>
                  Draft
                <% end %>
              </p>
              <p class="text-gray-700 dark:text-gray-300 text-sm line-clamp-2"><%= announcement.body %></p>
            </div>
            <div class="flex items-center gap-2 ml-4">
              <%= link_to "Edit", edit_admin_announcement_path(announcement), class: "text-sm text-sf-blue hover:underline" %>
              <%= button_to "Delete", admin_announcement_path(announcement), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-sm text-sf-red hover:underline cursor-pointer" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 text-center">
      <p class="text-gray-500 dark:text-gray-400">No announcements yet.</p>
    </div>
  <% end %>
</div>
