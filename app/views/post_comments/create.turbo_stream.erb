<% if @comment.parent_id? %>
  <%# Append reply under parent comment's replies container %>
  <%= turbo_stream.append "replies_for_#{@comment.parent_id}" do %>
    <%= render "post_comments/post_comment", comment: @comment, cohort: @cohort, post: @post %>
  <% end %>

  <%# Unhide the replies container if it was hidden %>
  <%= turbo_stream.replace "replies_for_#{@comment.parent_id}" do %>
    <div id="replies_for_<%= @comment.parent_id %>" class="ml-8 border-l-2 border-sf-sand/30 dark:border-gray-600 pl-3 mt-2 space-y-2">
      <% @comment.parent.replies.includes(:user).order(created_at: :asc).each do |reply| %>
        <%= render "post_comments/post_comment", comment: reply, cohort: @cohort, post: @post %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <%# Top-level comment: append to main comments list %>
  <%= turbo_stream.append "post_comments" do %>
    <%= render "post_comments/post_comment", comment: @comment, cohort: @cohort, post: @post %>
  <% end %>

  <%= turbo_stream.remove "no_comments_placeholder" %>
<% end %>
