<%= render layout: "shared/post_show", locals: {
  post: @post,
  editing: @editing,
  comments: @comments,
  new_comment: @new_comment,
  back_path: feed_posts_path,
  back_label: "Back to Feed",
  edit_path: edit_feed_post_path(@post),
  pin_path: feed_post_pin_path(@post),
  post_path: feed_post_path(@post),
  form_url: feed_post_path(@post),
  comment_form_model: [@post, @new_comment],
  comments_count: @post.feed_post_comments.count
} do %>
  <% @comments.each do |comment| %>
    <%= render "feed_post_comments/feed_post_comment", comment: comment, feed_post: @post %>
  <% end %>
<% end %>
