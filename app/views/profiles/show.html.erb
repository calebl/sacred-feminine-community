<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8">
    <div class="flex items-center gap-6 mb-6">
      <div class="w-20 h-20 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-2xl font-bold text-sf-black dark:text-white flex-shrink-0">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar.variant(:display), class: "w-20 h-20 rounded-full object-cover" %>
        <% else %>
          <%= @user.name.first.upcase %>
        <% end %>
      </div>
      <div>
        <h1 class="text-2xl font-display font-bold text-sf-black dark:text-white"><%= @user.name %></h1>
        <% if @user.city.present? || @user.state.present? || @user.country.present? %>
          <p class="text-gray-500 dark:text-gray-400"><%= @user.full_location %></p>
        <% end %>
      </div>
    </div>

    <% if @user.bio.present? %>
      <div class="mb-6">
        <h2 class="text-sm font-semibold text-sf-gold mb-2">About</h2>
        <p class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= @user.bio %></p>
      </div>
    <% end %>

    <% if @user.show_on_map && @user.latitude.present? && @user.longitude.present? %>
      <div class="mb-6">
        <h2 class="text-sm font-semibold text-sf-gold mb-2">Location</h2>
        <div
          data-controller="profile-map"
          data-profile-map-latitude-value="<%= @user.latitude %>"
          data-profile-map-longitude-value="<%= @user.longitude %>"
          class="w-full h-[300px] rounded-xl border border-sf-sand/20 dark:border-gray-700"
        ></div>
      </div>
    <% end %>

    <div class="flex gap-3">
      <% if @user == current_user %>
        <%= link_to "Edit Profile", edit_profile_path(@user), class: "px-5 py-2.5 bg-sf-gold text-white rounded-xl hover:bg-sf-gold/90 text-sm font-semibold transition shadow-sm" %>
      <% else %>
        <%= button_to "Send Message", conversations_path(recipient_id: @user.id), method: :post, class: "px-5 py-2.5 bg-sf-gold text-black rounded-xl hover:bg-sf-blue hover:text-white text-sm font-semibold transition shadow-sm cursor-pointer" %>
        <% if current_user.admin? %>
          <%= button_to "Remove User",
              admin_user_path(@user),
              method: :delete,
              class: "px-5 py-2.5 bg-sf-red/10 text-sf-red rounded-xl hover:bg-sf-red hover:text-white text-sm font-semibold transition shadow-sm cursor-pointer",
              data: { turbo_confirm: "Remove #{@user.name}? They will no longer be able to sign in." } %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
