<div class="max-w-2xl mx-auto px-4 py-8">
  <%= render "shared/back_header", path: profile_path(@user), title: "Edit Profile" %>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8">
    <%= form_with(model: @user, url: profile_path(@user), method: :patch, class: "space-y-6") do |f| %>
      <% if @user.errors.any? %>
        <div class="p-4 bg-sf-red/10 border border-sf-red/20 rounded-xl">
          <% @user.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-800 dark:text-red-300"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "w-full" %>
      </div>

      <div>
        <%= f.label :bio, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :bio, rows: 4, class: "w-full" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= f.label :city, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_field :city, class: "w-full" %>
        </div>
        <div>
          <%= f.label :state, "State / Province", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_field :state, class: "w-full" %>
        </div>
        <div>
          <%= f.label :country, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_field :country, class: "w-full" %>
        </div>
      </div>

      <div data-controller="image-cropper" data-image-cropper-aspect-ratio-value="1" data-image-cropper-file-name-value="cropped_avatar.jpg">
        <%= f.label :avatar, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <% if @user.avatar.attached? %>
          <div data-image-cropper-target="existingImage" class="mb-3">
            <%= image_tag @user.avatar.variant(:display), class: "w-16 h-16 rounded-full object-cover" %>
          </div>
          <label class="flex items-center gap-2 mb-3 text-sm text-gray-600 dark:text-gray-400">
            <%= check_box_tag "user[remove_avatar]", "1", false %>
            Remove current photo
          </label>
        <% end %>
        <%= f.file_field :avatar, accept: "image/*",
            data: { image_cropper_target: "fileInput", action: "change->image-cropper#fileSelected" },
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-sf-sand/30 file:text-sf-gold hover:file:bg-sf-sand/50 dark:file:bg-gray-700 dark:file:text-sf-sand" %>

        <div data-image-cropper-target="cropperWrap" class="hidden mt-3">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">Drag to reposition. The highlighted area will be used as your profile photo.</p>
          <div class="rounded-xl overflow-hidden border border-sf-sand/20 dark:border-gray-700" style="max-height: 400px;">
            <img data-image-cropper-target="source" class="max-w-full" alt="Crop source" />
          </div>
        </div>

        <div data-image-cropper-target="preview" class="hidden mt-3">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Preview:</p>
          <div class="w-24 h-24 rounded-full overflow-hidden border border-sf-sand/20 dark:border-gray-700">
            <img data-image-cropper-target="previewImage" class="w-full h-full object-cover" alt="Cropped preview" />
          </div>
        </div>

        <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Upload a profile photo. You can crop it after selecting.</p>
      </div>

      <div class="flex items-center gap-2">
        <%= f.check_box :show_on_map, class: "rounded border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
        <%= f.label :show_on_map, "Show me on the community map", class: "text-sm text-gray-700 dark:text-gray-300" %>
      </div>

      <fieldset>
        <legend class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Mentions</legend>
        <p class="text-xs text-gray-400 dark:text-gray-500 mb-3">Choose where other members can @mention you.</p>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
            <%= f.radio_button :mention_privacy, "everywhere", class: "border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
            Everywhere (groups, cohorts, and public feed)
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
            <%= f.radio_button :mention_privacy, "groups_and_cohorts", class: "border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
            Groups and cohorts only
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
            <%= f.radio_button :mention_privacy, "nobody", class: "border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
            No one
          </label>
        </div>
      </fieldset>

      <fieldset>
        <legend class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Private Messages</legend>
        <p class="text-xs text-gray-400 dark:text-gray-500 mb-3">Choose who can send you direct messages.</p>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
              <%= f.radio_button :dm_privacy, "everyone", class: "border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
              Everyone
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
              <%= f.radio_button :dm_privacy, "cohort_members", class: "border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
              Members of my cohorts only
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
              <%= f.radio_button :dm_privacy, "nobody", class: "border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
              No one
            </label>
          </div>
          <% if @user.dm_privacy_nobody? %>
            <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">Community admins can still send you messages.</p>
          <% end %>
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-sf-sand/10 dark:border-gray-700"
             data-controller="notification-preview"
             data-notification-preview-name-value="<%= @user.name %>"
             data-notification-preview-initial-value="<%= @user.name.first.upcase %>"
             <% if @user.avatar.attached? %>data-notification-preview-avatar-url-value="<%= rails_representation_path(@user.avatar.variant(:display)) %>"<% end %>>
          <%= f.check_box :dm_notifications, class: "rounded border-gray-300 text-sf-gold focus:ring-sf-gold dark:bg-gray-700 dark:border-gray-600" %>
          <%= f.label :dm_notifications, "Show message notification popups", class: "text-sm text-gray-700 dark:text-gray-300" %>
          <button type="button" data-action="notification-preview#preview"
                  class="ml-auto text-xs text-sf-gold hover:text-sf-blue transition cursor-pointer">Preview</button>
        </div>
      </fieldset>

      <div>
        <%= f.submit "Save Profile", class: "btn-primary" %>
      </div>
    <% end %>

    <div class="mt-8 pt-6 border-t border-sf-sand/20 dark:border-gray-700">
      <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-3">Account Settings</h2>
      <div class="flex gap-3">
        <%= link_to "Change Email", edit_account_email_path, class: "text-sm text-sf-gold hover:text-sf-blue transition" %>
        <%= link_to "Change Password", edit_account_password_path, class: "text-sm text-sf-gold hover:text-sf-blue transition" %>
      </div>
    </div>
  </div>
</div>
