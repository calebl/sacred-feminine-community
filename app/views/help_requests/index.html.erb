<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-display font-bold text-sf-black dark:text-white">Help Desk</h1>
  <%= link_to "Ask for Help", new_help_request_path, class: "btn-primary px-5 py-2.5" %>
</div>

<% if @help_requests.any? %>
  <div class="space-y-3">
    <% @help_requests.each do |request| %>
      <%= link_to help_request_path(request), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-4 hover:shadow-md transition" do %>
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-semibold text-sf-black dark:text-white truncate"><%= request.subject %></h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2"><%= truncate(request.body, length: 120) %></p>
            <div class="flex items-center gap-3 mt-2 text-xs text-gray-400 dark:text-gray-500">
              <% if current_user.admin? %>
                <span>From: <%= request.user.name %></span>
                <span>&middot;</span>
              <% end %>
              <span><%= time_ago_in_words(request.created_at) %> ago</span>
              <span>&middot;</span>
              <span><%= request.help_request_replies.count %> <%= "reply".pluralize(request.help_request_replies.count) %></span>
            </div>
          </div>
          <span class="shrink-0 inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium
            <%= request.open? ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' %>">
            <%= request.status.capitalize %>
          </span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 p-8 text-center">
    <p class="text-gray-500 dark:text-gray-400">No help requests yet.</p>
  </div>
<% end %>
