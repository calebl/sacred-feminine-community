<%= form_with(model: help_request, class: "space-y-6") do |form| %>
  <% if help_request.errors.any? %>
    <div class="bg-sf-red/10 border border-sf-red/20 rounded-xl p-4">
      <ul class="list-disc list-inside text-sm text-sf-red">
        <% help_request.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :subject, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.text_field :subject, class: "w-full rounded-xl border border-sf-sand/40 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-3 text-sm text-sf-black dark:text-white focus:ring-2 focus:ring-sf-gold/50 focus:border-sf-gold transition", placeholder: "Brief summary of what you need help with" %>
  </div>

  <div>
    <%= form.label :body, "Details", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.text_area :body, rows: 6, class: "w-full rounded-xl border border-sf-sand/40 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-3 text-sm text-sf-black dark:text-white focus:ring-2 focus:ring-sf-gold/50 focus:border-sf-gold transition", placeholder: "Describe what you need help with in detail..." %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit "Submit Request", class: "btn-primary px-6 py-3 cursor-pointer" %>
    <%= link_to "Cancel", help_requests_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
  </div>
<% end %>
