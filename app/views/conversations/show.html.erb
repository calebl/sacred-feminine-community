<div class="max-w-2xl mx-auto px-4 py-8">
  <%= render layout: "shared/back_header", locals: { path: conversations_path } do %>
    <% if @other_user %>
      <div class="w-10 h-10 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-lg font-bold text-sf-black dark:text-white">
        <% if @other_user.avatar.attached? %>
          <%= image_tag @other_user.avatar.variant(:display), class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <%= @other_user.name.first.upcase %>
        <% end %>
      </div>
      <div>
        <% if @other_user.kept? %>
          <%= link_to @other_user.name, profile_path(@other_user), class: "font-display font-semibold text-sf-black dark:text-white hover:text-sf-gold transition" %>
        <% else %>
          <span class="font-display font-semibold text-gray-400 dark:text-gray-500"><%= @other_user.name %></span>
          <span class="text-xs text-gray-400 dark:text-gray-500 ml-1">(removed)</span>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-hidden">
    <%= turbo_stream_from @conversation %>

    <div id="direct_messages" class="h-[500px] overflow-y-auto p-4 space-y-2 flex flex-col" data-controller="scroll-bottom chat-alignment" data-chat-alignment-user-id-value="<%= current_user.id %>">
      <% if @messages.any? %>
        <% @messages.each do |message| %>
          <%= render "direct_messages/direct_message", direct_message: message %>
        <% end %>
      <% else %>
        <p id="no_messages_placeholder" class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">No messages yet. Say hello!</p>
      <% end %>
    </div>

    <% if @other_user&.kept? %>
      <div class="p-4 border-t border-sf-sand/20 dark:border-gray-700">
        <%= form_with(
          model: [@conversation, DirectMessage.new],
          class: "flex gap-2",
          data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" }
        ) do |f| %>
          <%= f.text_field :body,
            placeholder: "Type a message...",
            class: "flex-1",
            autocomplete: "off",
            required: true %>
          <%= f.submit "Send",
            class: "btn-primary py-2.5" %>
        <% end %>
      </div>
    <% else %>
      <div class="p-4 border-t border-sf-sand/20 dark:border-gray-700 text-center">
        <p class="text-gray-400 dark:text-gray-500 text-sm">This user has been removed. You can no longer send messages.</p>
      </div>
    <% end %>
  </div>
</div>
