<div class="max-w-2xl mx-auto px-4 py-8">
  <%= render layout: "shared/back_header", locals: { path: conversations_path } do %>
    <% if @other_users.any? %>
      <% first_other = @other_users.first %>
      <div class="w-10 h-10 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-lg font-bold text-sf-black dark:text-white">
        <% if first_other.avatar.attached? %>
          <%= image_tag first_other.avatar.variant(:display), class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <%= first_other.name.first.upcase %>
        <% end %>
      </div>
      <div>
        <% if @other_users.size == 1 %>
          <% if first_other.kept? %>
            <%= link_to first_other.name, profile_path(first_other), class: "font-display font-semibold text-sf-black dark:text-white hover:text-sf-gold transition" %>
          <% else %>
            <span class="font-display font-semibold text-gray-400 dark:text-gray-500"><%= first_other.name %></span>
            <span class="text-xs text-gray-400 dark:text-gray-500 ml-1">(removed)</span>
          <% end %>
        <% else %>
          <span class="font-display font-semibold text-sf-black dark:text-white"><%= @conversation.display_name(current_user) %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-hidden">
    <%= turbo_stream_from @conversation %>

    <div id="direct_messages" class="h-[500px] overflow-y-auto p-4 space-y-2 flex flex-col" data-controller="scroll-bottom chat-alignment" data-chat-alignment-user-id-value="<%= current_user.id %>">
      <% if @messages.any? %>
        <% @messages.each do |message| %>
          <%= render "direct_messages/direct_message", direct_message: message %>
        <% end %>
      <% else %>
        <p id="no_messages_placeholder" class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">No messages yet. Say hello!</p>
      <% end %>
    </div>

    <% if @other_users.any?(&:kept?) %>
      <div class="p-4 border-t border-sf-sand/20 dark:border-gray-700">
        <div data-controller="mention"
             data-mention-url-value="<%= mention_searches_path %>"
             data-mention-conversation-id-value="<%= @conversation.id %>"
             class="relative">
          <%= form_with(
            model: [@conversation, DirectMessage.new],
            class: "flex gap-2",
            data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" }
          ) do |f| %>
            <%= f.hidden_field :body, data: { mention_target: "hidden" } %>
            <div contenteditable="true"
                 data-mention-target="input"
                 data-action="input->mention#onInput keydown->mention#onKeydown blur->mention#hide paste->mention#onPaste"
                 data-placeholder="Type a message... (@ to mention)"
                 data-single-line
                 class="flex-1 border-gray-300 rounded-xl shadow-sm px-4 py-3 text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 focus:outline-none focus:ring-1 focus:ring-sf-gold focus:border-sf-gold overflow-x-hidden whitespace-nowrap overflow-y-hidden border"
                 role="textbox"></div>
            <%= f.submit "Send",
              class: "btn-primary py-2.5" %>
          <% end %>
          <div data-mention-target="dropdown" class="hidden absolute left-0 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg max-h-48 overflow-y-auto"></div>
        </div>
      </div>
    <% else %>
      <div class="p-4 border-t border-sf-sand/20 dark:border-gray-700 text-center">
        <p class="text-gray-400 dark:text-gray-500 text-sm">All participants have been removed. You can no longer send messages.</p>
      </div>
    <% end %>
  </div>
</div>
