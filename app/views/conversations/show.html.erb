<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to conversations_path, class: "p-2 rounded-lg text-gray-400 hover:text-sf-red hover:bg-sf-sand/20 dark:hover:bg-gray-700 transition" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <% if @other_user %>
      <div class="w-10 h-10 rounded-full bg-sf-sand/50 dark:bg-gray-700 flex items-center justify-center text-lg font-bold text-sf-black dark:text-white">
        <% if @other_user.avatar.attached? %>
          <%= image_tag @other_user.avatar.variant(resize_to_fill: [40, 40]), class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <%= @other_user.name.first.upcase %>
        <% end %>
      </div>
      <div>
        <%= link_to @other_user.name, profile_path(@other_user), class: "font-display font-semibold text-sf-black dark:text-white hover:text-sf-red transition" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-sf-sand/20 dark:border-gray-700 overflow-hidden">
    <%= turbo_stream_from @conversation %>

    <div id="direct_messages" class="h-[500px] overflow-y-auto p-4 space-y-2 flex flex-col" data-controller="scroll-bottom">
      <% if @messages.any? %>
        <% @messages.each do |message| %>
          <%= render "direct_messages/direct_message", direct_message: message %>
        <% end %>
      <% else %>
        <p class="text-center text-gray-400 dark:text-gray-500 text-sm py-8">No messages yet. Say hello!</p>
      <% end %>
    </div>

    <div class="p-4 border-t border-sf-sand/20 dark:border-gray-700">
      <%= form_with(
        model: [@conversation, DirectMessage.new],
        class: "flex gap-2",
        data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" }
      ) do |f| %>
        <%= f.text_field :body,
          placeholder: "Type a message...",
          class: "flex-1",
          autocomplete: "off",
          required: true %>
        <%= f.submit "Send",
          class: "px-6 py-2.5 bg-sf-red text-white rounded-xl hover:bg-sf-red/90 font-semibold transition cursor-pointer shadow-sm text-sm" %>
      <% end %>
    </div>
  </div>
</div>
