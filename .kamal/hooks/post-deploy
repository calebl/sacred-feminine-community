#!/bin/sh

# Post-deploy hook: tags the release and records changelog in the database.
#
# Available environment variables:
# KAMAL_RECORDED_AT, KAMAL_PERFORMER, KAMAL_VERSION, KAMAL_HOSTS,
# KAMAL_COMMAND, KAMAL_SUBCOMMAND, KAMAL_ROLES, KAMAL_DESTINATION, KAMAL_RUNTIME

set -e

# Generate a version tag from the current timestamp
VERSION="v$(date -u +%Y.%m.%d.%H%M%S)"
COMMIT_SHA=$(git rev-parse HEAD)
DEPLOYED_AT=$(date -u +"%Y-%m-%d %H:%M:%S")

# Tag the release locally and push the tag
git tag -a "$VERSION" -m "Release $VERSION"
git push origin "$VERSION"

echo "Tagged release: $VERSION"

# Record the release in the database via rake task on the server.
# The rake task generates the changelog from git history directly.
if ! kamal app exec --reuse "bin/rake 'releases:record[$VERSION,$COMMIT_SHA,$DEPLOYED_AT]'"; then
  echo "Release record failed. Cleaning up tag $VERSION..."
  git tag -d "$VERSION" 2>/dev/null
  git push origin --delete "$VERSION" 2>/dev/null
  exit 1
fi

echo "Release $VERSION recorded in changelog."
